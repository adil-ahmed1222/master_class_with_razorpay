# NeuralVarsity Masterclass — environment configuration template.
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# Validated at startup by src/lib/env.ts.

# ---- Client (browser-exposed; must be prefixed NEXT_PUBLIC_) ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_ANALYTICS_ENABLED="false"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"

# ---- Server-only (never exposed to the browser) ----
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
